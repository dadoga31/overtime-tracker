// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own entries
    match /entries/{entryId} {
      allow read, delete: if request.auth != null
                          && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid','date','hours','client','location','createdAt'])
                    && request.resource.data.hours is number
                    && request.resource.data.hours > 0
                    && request.resource.data.hours <= 24;

      allow update: if false; // entries are immutable once created
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
